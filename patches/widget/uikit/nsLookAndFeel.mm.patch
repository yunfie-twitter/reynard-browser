 using namespace mozilla;
 
+static bool sSystemUsesDarkTheme;
+static bool sSystemUsesDarkThemeInitialized;
+
+static bool GetSystemUsesDarkTheme() {
+  if (!sSystemUsesDarkThemeInitialized) {
+    sSystemUsesDarkThemeInitialized = true;
+    sSystemUsesDarkTheme =
+        [UIScreen mainScreen].traitCollection.userInterfaceStyle ==
+        UIUserInterfaceStyleDark;
+  }
+  return sSystemUsesDarkTheme;
+}
+
+static UITraitCollection* TraitCollectionForScheme(ColorScheme aColorScheme) {
+  const auto style = aColorScheme == ColorScheme::Dark
+                         ? UIUserInterfaceStyleDark
+                         : UIUserInterfaceStyleLight;
+  return [UITraitCollection traitCollectionWithUserInterfaceStyle:style];
+}
+
 nsLookAndFeel::nsLookAndFeel() : mInitialized(false) {}
 
 nsLookAndFeel::~nsLookAndFeel() {}
 
+void nsLookAndFeel::SetSystemUsesDarkTheme(bool aUseDarkTheme) {
+  if (sSystemUsesDarkThemeInitialized &&
+      sSystemUsesDarkTheme == aUseDarkTheme) {
+    return;
+  }
+
+  sSystemUsesDarkThemeInitialized = true;
+  sSystemUsesDarkTheme = aUseDarkTheme;
+
+  // REYNARD: Recompute cached UIKit look-and-feel values when the host view's
+  // trait collection changes so Gecko can follow the current interface style.
+  LookAndFeel::NotifyChangedAllWindows(widget::ThemeChangeKind::StyleAndLayout);
+}
