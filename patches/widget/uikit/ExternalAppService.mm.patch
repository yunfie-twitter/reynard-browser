+mozilla::StaticRefPtr<ExternalAppService> ExternalAppService::sService;
+
+already_AddRefed<ExternalAppService> ExternalAppService::GetSingleton() {
+  if (!sService) {
+    sService = new ExternalAppService();
+  }
+
+  RefPtr<ExternalAppService> service = sService;
+  return service.forget();
+}
+
+ExternalAppService::ExternalAppService() = default;
+
+NS_IMPL_ISUPPORTS(ExternalAppService, nsIExternalHelperAppService)
+
+NS_IMETHODIMP ExternalAppService::DoContent(
+    const nsACString& aMimeContentType, nsIChannel* aChannel,
+    nsIInterfaceRequestor* aContentContext, bool aForceSave,
+    nsIInterfaceRequestor* aWindowContext,
+    nsIStreamListener** aStreamListener) {
+  return NS_ERROR_FAILURE;
+}
+
+NS_IMETHODIMP ExternalAppService::CreateListener(
+    const nsACString& aMimeContentType, nsIChannel* aChannel,
+    mozilla::dom::BrowsingContext* aContentContext, bool aForceSave,
+    nsIInterfaceRequestor* aWindowContext,
+    nsIStreamListener** aStreamListener) {
+  MOZ_ASSERT(XRE_IsParentProcess());
+  NS_ENSURE_ARG_POINTER(aChannel);
+  NS_ENSURE_ARG_POINTER(aContentContext);
+  NS_ENSURE_ARG_POINTER(aStreamListener);
+
+  nsCOMPtr<nsIWidget> widget =
+      aContentContext->Canonical()->GetParentProcessWidgetContaining();
+  if (!widget) {
+    return NS_ERROR_ABORT;
+  }
+
+  RefPtr<nsWindow> window = nsWindow::From(widget);
+  if (NS_WARN_IF(!window) || NS_WARN_IF(window->Destroyed())) {
+    return NS_ERROR_ABORT;
+  }
+
+  RefPtr<ExternalResponseListener> listener =
+      new ExternalResponseListener(window);
+  nsresult rv = aChannel->SetNotificationCallbacks(listener);
+  NS_ENSURE_SUCCESS(rv, rv);
+
+  listener.forget(aStreamListener);
+  return NS_OK;
+}
+
+NS_IMETHODIMP ExternalAppService::ApplyDecodingForExtension(
+    const nsACString& aExtension, const nsACString& aEncodingType,
+    bool* aApplyDecoding) {
+  *aApplyDecoding = true;
+  return NS_OK;
+}
+
+NS_IMETHODIMP ExternalAppService::GetPreferredDownloadsDirectory(
+    nsIFile** aResult) {
+  NS_ENSURE_ARG_POINTER(aResult);
+  *aResult = nullptr;
+  return NS_ERROR_NOT_IMPLEMENTED;
+}
