+// REYNARD: Wait for the parent process to finish the per-pid JIT attach path
+// before allowing the content child to keep SpiderMonkey JIT enabled.
+static bool WaitForJITReadySignal(mozilla::widget::ChildJITStatus* aStatus) {
+  auto finish = [&](bool ok) {
+    if (gJITReadySignalFd != -1) {
+      close(gJITReadySignalFd);
+      gJITReadySignalFd = -1;
+    }
+    return ok;
+  };
+
+  if (gJITReadySignalFd == -1) {
+    return finish(false);
+  }
+
+  pollfd descriptor = {
+      .fd = gJITReadySignalFd,
+      .events = POLLIN,
+      .revents = 0,
+  };
+
+  const int pollResult = poll(&descriptor, 1, 5000);
+  if (pollResult <= 0) {
+    return finish(false);
+  }
+
+  mozilla::widget::ChildJITStatus status = {0, 0};
+  const ssize_t bytesRead = read(gJITReadySignalFd, &status, sizeof(status));
+
+  if (bytesRead != sizeof(status)) {
+    return finish(false);
+  }
+
+  if (aStatus) {
+    *aStatus = status;
+  }
+
+  return finish(status.enabled);
+}
