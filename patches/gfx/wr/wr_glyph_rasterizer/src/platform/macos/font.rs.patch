+#[cfg(target_os = "ios")]
+fn new_hidden_system_ui_font(name: &str) -> CTFont {
+    let system_font = core_text::font::new_ui_font_for_language(
+        core_text::font::kCTFontSystemFontType,
+        0.0,
+        None,
+    );
+    let (trait_value, trait_mask) = hidden_system_font_traits(name);
+    if trait_mask != 0 {
+        system_font
+            .clone_with_symbolic_traits(trait_value, trait_mask)
+            .unwrap_or(system_font)
+    } else {
+        system_font
+    }
