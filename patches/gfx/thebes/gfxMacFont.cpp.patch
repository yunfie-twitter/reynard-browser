+// REYNARD: Pull the preserved CoreText descriptor from the unscaled font so
+// metrics and glyph measurement can recreate the original Apple system font.
+static CTFontDescriptorRef GetUnscaledFontDescriptor(const gfxMacFont* aFont) {
+  auto* unscaledFont =
+      static_cast<UnscaledFontMac*>(aFont->GetUnscaledFont().get());
+  return unscaledFont ? unscaledFont->GetFontDescriptorRef() : nullptr;
+}
